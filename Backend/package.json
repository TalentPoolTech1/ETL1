{
  "name": "etl-codegen-engine",
  "version": "1.0.0",
  "description": "Enterprise ETL Code Generation Engine - multi-technology, template-driven",
  "main": "dist/codegen/codegen.service.js",
  "types": "dist/codegen/codegen.service.d.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/api/server.js",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/api/server.ts",
    "migrate": "ts-node -e \"require('./src/db/migration-runner').runMigrations()\"",
    "test:integration": "ts-node src/codegen/__tests__/pyspark.integration.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "avro-js": "^1.12.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mssql": "^12.2.1",
    "mysql2": "^3.20.0",
    "oracledb": "^6.10.0",
    "parquetjs-lite": "^0.8.7",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@types/winston": "^2.4.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
