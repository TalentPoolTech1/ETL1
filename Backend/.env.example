# ETL1 Backend — Environment Variables Template
#
# INSTRUCTIONS:
#   1. Copy this file to .env in the same directory
#   2. Replace every placeholder value with your actual values
#   3. NEVER commit .env to Git — it is in .gitignore
#   4. Keep this .env.example file up to date when new variables are added
#
# See Docs/ENV_VARIABLES_GUIDE.md for full documentation of every variable.

# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────

# TCP port the Express API server listens on.
# Must match VITE_API_URL port in Frontend/.env
PORT=3000

# Node.js environment mode. Controls error verbosity and library behaviour.
# Values: development | test | production
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL Database
# ─────────────────────────────────────────────────────────────────────────────

# Hostname or IP address of the PostgreSQL server.
# Local: localhost | Docker: localhost | Cloud RDS: <instance>.rds.amazonaws.com
DB_HOST=localhost

# PostgreSQL port. Default is 5432.
DB_PORT=5432

# PostgreSQL username. Use a least-privilege account in production (not postgres superuser).
DB_USER=postgres

# PostgreSQL password. Use a strong random password in production.
# Minimum 20 characters for production environments.
# NEVER use 'admin123' or any dictionary word in production.
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# PostgreSQL database name.
# Use separate databases per environment: etl_db | etl_db_qa | etl_db_staging | etl_db_prod
DB_NAME=etl_db

# ─────────────────────────────────────────────────────────────────────────────
# Security — JWT Authentication
# ─────────────────────────────────────────────────────────────────────────────

# Secret key used to sign JSON Web Tokens (JWTs).
# Changing this invalidates ALL existing user sessions.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Minimum 32 characters. Must be different in every environment.
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHAR_HEX_STRING

# Current JWT secret (same purpose as JWT_SECRET — kept for migration compatibility).
# Set both to the same value.
APP_JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHAR_HEX_STRING

# ─────────────────────────────────────────────────────────────────────────────
# Security — Data Encryption
# ─────────────────────────────────────────────────────────────────────────────

# AES-256 encryption key for connection credentials stored in PostgreSQL.
# Used by pgcrypto to encrypt passwords, API keys, and OAuth secrets at rest.
# MUST be exactly 32 characters.
# WARNING: Once data is encrypted with this key, changing it makes all
# stored credentials unreadable. Back up this key and never lose it.
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
APP_ENCRYPTION_KEY=CHANGE_ME_EXACTLY_32_CHARACTERS_XX

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────

# Minimum log level written to log files.
# Values (lowest to highest): trace | debug | info | warn | error | fatal
# Recommended: debug (dev) | info (qa/staging) | warn (production)
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────────────────────

# The exact origin URL of the frontend application.
# The browser blocks API calls from any origin not listed here.
# Local dev: http://localhost:5173
# Production: https://etl1.yourcompany.com
# Do NOT use * (wildcard) in production — security risk.
CORS_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# Optional — Future variables (add when features are built)
# ─────────────────────────────────────────────────────────────────────────────

# SMTP for alert email notifications
# SMTP_HOST=smtp.yourcompany.com
# SMTP_PORT=587
# SMTP_USER=etl-alerts@yourcompany.com
# SMTP_PASSWORD=CHANGE_ME

# Slack webhook for alert notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE/ME/CHANGEME

# Spark cluster submission endpoint
# SPARK_MASTER_URL=spark://localhost:7077

# Redis for session caching (future)
# REDIS_URL=redis://localhost:6379

# Object storage for generated code and execution artifacts
# S3_BUCKET=etl1-artifacts
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME
